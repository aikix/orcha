{
  "name": "orcha",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.22",
  "bin": {
    "orcha": "apps/cli/src/index.ts"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:cli": "bun apps/cli/src/index.ts",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "build:binary": "bun build apps/cli/src/index.ts --compile --outfile dist/orcha",
    "build:binaries": "bun run scripts/build-binaries.ts"
  },
  "devDependencies": {
    "@types/node": "^24.3.1",
    "bun-types": "^1.3.2",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2"
  }
}
